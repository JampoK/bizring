{
  "name": "linkedin-for-businesses",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "pnpm -r run dev",
    "build": "pnpm -r run build",
    "lint": "eslint . --ext .ts,.js,.jsx,.json",
    "typecheck": "tsc --noEmit",
    "validate": "ts-node packages/shared/src/env.ts",
    "clean": "pnpm run clean:build && pnpx ts-node scripts/clean.ts",
    "clean:build": "rm -rf dist && rm -rf apps/frontend/.next",
    "prepare": "husky install"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint": "^8.53.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.28.0",
    "husky": "^9.1.7",
    "lint-staged": "^12.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.3.0",
    "zod": "^3.25.76"
  },
  "dependencies": {
    "concurrently": "^7.3.0",
    "ts-node": "^10.9.0"
  }
}