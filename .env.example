# Development (local)
# Copy this to .env.local and fill in the values for local development.

# Server-only environment variables (not exposed to client)
# These are required for server startup and database connectivity
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
JWT_SECRET=super-secret-development-key
JWT_EXPIRES_IN=7d
JWT_ISSUER=linkedin-for-businesses
API_RATE_LIMIT=1000

# Public environment variables (exposed to client)
NEXT_PUBLIC_APP_NAME=LinkedIn for Businesses
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Staging environment (copy to .env.staging and fill in values)
# Server-only
DB_HOST=staging-db.example.com
DB_PORT=5432
DB_USER=staging_user
DB_PASSWORD=staging-password
JWT_SECRET=staging-super-secret-key
JWT_EXPIRES_IN=7d
JWT_ISSUER=linkedin-for-businesses-staging
API_RATE_LIMIT=500

NEXT_PUBLIC_APP_NAME=LinkedIn for Businesses
NEXT_PUBLIC_APP_URL=https://staging.example.com
NEXT_PUBLIC_API_URL=https://api.staging.example.com

# Production environment (copy to .env.production and fill in values)
# Server-only
DB_HOST=prod-db.example.com
DB_PORT=5432
DB_USER=prod_user
DB_PASSWORD=production-password
JWT_SECRET=production-super-secret-key
JWT_EXPIRES_IN=7d
JWT_ISSUER=linkedin-for-businesses
API_RATE_LIMIT=1000

NEXT_PUBLIC_APP_NAME=LinkedIn for Businesses
NEXT_PUBLIC_APP_URL=https://app.example.com
NEXT_PUBLIC_API_URL=https://api.example.com